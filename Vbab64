Private Sub Document_New()
    Init
End Sub

Private Sub AutoOpen()
    Init
End Sub

Sub Init()
    Call DecodeAndRestore
End Sub

Function XORDecode(text As String, key As Integer) As String
    Dim i As Long
    Dim result As String
    
    For i = 1 To Len(text)
        result = result & Chr(Asc(Mid(text, i, 1)) Xor key)
    Next i
    
    XORDecode = result
End Function

Sub DecodeAndRestore()
    Dim encoded As String
    Dim decoded As String
    
    ' Lấy toàn bộ nội dung hiện tại (đã encode)
    encoded = ActiveDocument.Content.Text
    
    ' Decode
    decoded = XORDecode(encoded, 23)
    
    ' Ghi đè lại nội dung thật
    ActiveDocument.Content.Text = decoded
    
    ' Set lại font cho đẹp
    With ActiveDocument.Content.Font
        .Name = "Times New Roman"
        .Size = 12
    End With
End Sub
